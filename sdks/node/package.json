{
  "name": "dcoink",
  "version": "0.1.0",
  "description": "The official zero-dependency Node.js/TypeScript SDK for dco.ink",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "tsx test.ts"
  },
  "keywords": [
    "dcoink",
    "url-shortener",
    "api",
    "sdk"
  ],
  "author": "dco.ink <hello@dco.ink>",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3"
  }
}
